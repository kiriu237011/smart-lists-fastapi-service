# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
